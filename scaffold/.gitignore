# llmzk installed-vault defaults
# Track notes and Logs by default so Git can act as the safety/review layer.
# If a private vault should not track raw inputs or media, add local ignore rules below.

# Python/cache noise
.venv/
**/.venv/
__pycache__/
*.py[cod]
.pytest_cache/
.ruff_cache/
.mypy_cache/

# OpenCode / JS caches
node_modules/
.opencode/node_modules/

# OS/editor noise
.DS_Store
__MACOSX/

# Large/generated media can be noisy; uncomment if desired.
# 09 Media/**
# !09 Media/
# !09 Media/.gitkeep

# Optional privacy rules for a private local vault; uncomment if desired.
# 00 Inbox/**
# !00 Inbox/
# !00 Inbox/.gitkeep
# 00 Fleeting Notes/**
# !00 Fleeting Notes/
# !00 Fleeting Notes/.gitkeep
