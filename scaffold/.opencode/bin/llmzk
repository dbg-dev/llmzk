#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'USAGE'
Usage: .opencode/bin/llmzk <command> [args]

Commands:
  audit                 Run vault audit
  benchmark             Run regression benchmark expectations
  doctor                Check installed vault health
  update                Report or update installed system layer from upstream scaffold
  fix-frontmatter       Normalize frontmatter link-list fields
  normalize-links       Normalize wikilinks outside code fences
  new-run               Create passport and decision-log placeholders
  review                Validate, mark, or normalize candidate reviews
  review-validate       Validate a candidate review file
  git <subcommand>      Run Git safety subcommands
  git-safety <args>     Direct access to llmzk-git-safety

Examples:
  .opencode/bin/llmzk audit .
  .opencode/bin/llmzk benchmark .opencode/benchmarks --vault .
  .opencode/bin/llmzk doctor .
  .opencode/bin/llmzk update . --source /path/to/llmzk
  .opencode/bin/llmzk update . --source /path/to/llmzk --apply
  .opencode/bin/llmzk git preflight .
  .opencode/bin/llmzk git diff . --stat
  .opencode/bin/llmzk review validate "Logs/Candidate Reviews/example.md"
  .opencode/bin/llmzk review normalize "Logs/Candidate Reviews/example.md"
  .opencode/bin/llmzk review validate -- "Logs/Candidate Reviews/-example.md"
USAGE
}

find_vault_root_from_dir() {
  local dir="$1"
  while [[ "$dir" != "/" ]]; do
    if [[ -f "$dir/.opencode/llmzk-tools/pyproject.toml" ]]; then
      printf '%s\n' "$dir"
      return 0
    fi
    dir="$(dirname "$dir")"
  done
  return 1
}

find_vault_root_from_invocation() {
  local script_path="${BASH_SOURCE[0]}"
  if [[ "$script_path" != /* ]]; then
    script_path="$PWD/$script_path"
  fi
  # Do not resolve symlinks here. In symlink install mode the textual path
  # through <vault>/.opencode/bin/llmzk is the vault we want.
  local candidate
  candidate="$(cd "$(dirname "$script_path")/../.." && pwd -L)"
  if [[ -f "$candidate/.opencode/llmzk-tools/pyproject.toml" ]]; then
    printf '%s\n' "$candidate"
    return 0
  fi
  return 1
}

VAULT_ROOT="$(find_vault_root_from_dir "$PWD" || find_vault_root_from_invocation || true)"
if [[ -z "$VAULT_ROOT" ]]; then
  echo "Could not find vault root containing .opencode/llmzk-tools/pyproject.toml" >&2
  exit 1
fi

PROJECT="$VAULT_ROOT/.opencode/llmzk-tools"

run_tool() {
  uv run --project "$PROJECT" "$@"
}

if [[ $# -eq 0 ]]; then
  usage
  exit 1
fi

cmd="$1"
shift

case "$cmd" in
  audit)
    run_tool llmzk-audit "$@"
    ;;
  benchmark)
    run_tool llmzk-benchmark "$@"
    ;;
  doctor)
    run_tool llmzk-doctor "$@"
    ;;
  update)
    run_tool llmzk-update "$@"
    ;;
  fix-frontmatter)
    run_tool llmzk-fix-frontmatter "$@"
    ;;
  normalize-links)
    run_tool llmzk-normalize-links "$@"
    ;;
  new-run)
    run_tool llmzk-new-run "$@"
    ;;

  review)
    run_tool llmzk-review "$@"
    ;;
  review-validate)
    run_tool llmzk-review validate "$@"
    ;;
  git)
    if [[ $# -eq 0 ]]; then
      echo "Missing Git safety subcommand." >&2
      echo "Try: .opencode/bin/llmzk git status ." >&2
      exit 1
    fi
    run_tool llmzk-git-safety "$@"
    ;;
  git-safety)
    run_tool llmzk-git-safety "$@"
    ;;
  -h|--help|help)
    usage
    ;;
  *)
    echo "Unknown llmzk command: $cmd" >&2
    usage >&2
    exit 1
    ;;
esac
